#!/usr/bin/env bash
#
# sl-mount — wire this cdktn-planning checkout into a cdk-terrain checkout.
#
# Drops locally-ignored symlinks into a contributor's cdk-terrain so the
# SpecLedger tooling works in place, while the planning artifacts themselves
# stay in cdktn-planning and out of cdk-terrain's git history. PRs against
# cdk-terrain stay small and code-only.
#
# What it does (idempotent):
#   1. Symlinks each .agents/commands/specledger.*.md -> <cdk-terrain>/.claude/commands/
#   2. Symlinks each .agents/skills/sl-*             -> <cdk-terrain>/.claude/skills/
#   3. Symlinks  specledger/  and  .specledger/      -> <cdk-terrain>/ (whole dirs)
#   4. Writes <cdk-terrain>/mise.local.toml (untracked) providing the `sl` CLI
#   5. Adds every linked path to <cdk-terrain>/.git/info/exclude — a LOCAL,
#      never-committed ignore file — so none of it can leak into a commit
#
# It NEVER symlinks the .claude/commands or .claude/skills *folders* — only the
# individual specledger.*/sl-* entries — so a checked-in .claude/ is preserved,
# and it refuses to clobber any real (non-symlink) file of the same name.
#
# Usage:  ./scripts/sl-mount [PATH_TO_CDK_TERRAIN]   (prompts if omitted)
# Undo:   ./scripts/sl-unmount [PATH_TO_CDK_TERRAIN]
#
set -euo pipefail
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_sl-common.sh"

case "${1:-}" in -h|--help) sed -n '2,23p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'; exit 0 ;; esac

resolve_target "${1:-}"
CONFLICTS=0

echo "Mounting cdktn-planning -> $TARGET"
echo "  planning root: $PLANNING_ROOT"
echo
mkdir -p "$TARGET/.claude/commands" "$TARGET/.claude/skills"

echo "commands:";  for_each_command link_one
echo "skills:";    for_each_skill   link_one
echo "workspace:"
link_one "$PLANNING_ROOT/specledger"  "$TARGET/specledger"
link_one "$PLANNING_ROOT/.specledger" "$TARGET/.specledger"

echo "local ignore (.git/info/exclude):"
exclude_add "/.claude/commands/specledger.*.md"
exclude_add "/.claude/skills/sl-*"
exclude_add "/specledger"
exclude_add "/.specledger"
exclude_add "/mise.local.toml"
note "updated ${EXCLUDE#"$TARGET"/}"

echo "sl CLI (mise.local.toml):"
ML="$TARGET/mise.local.toml"
if [[ ! -e "$ML" ]]; then
  cat > "$ML" <<EOF
# Local mise config — NOT committed (see .git/info/exclude).
# Provides the SpecLedger CLI (\`sl\`) for planning work in cdk-terrain.
# Generated by $MARKER — safe to delete & re-run.
[tools]
"github:specledger/specledger" = "$SL_VERSION"
EOF
  note "wrote   mise.local.toml"
elif grep -q 'specledger/specledger' "$ML"; then
  note "ok      mise.local.toml (already provides sl)"
else
  warn "mise.local.toml exists without sl — add manually:"
  warn '    [tools]'
  warn "    \"github:specledger/specledger\" = \"$SL_VERSION\""
fi

echo
[[ "$CONFLICTS" -ne 0 ]] && echo "⚠ Finished with conflicts above — those entries were NOT linked." >&2
cat <<EOF
Done. Next:
  cd "$TARGET"
  mise install        # fetches the sl CLI declared in mise.local.toml
  sl --version        # verify
Re-run any time (idempotent). To undo: ${BASH_SOURCE[0]%/*}/sl-unmount "$TARGET"
EOF
